# HeatGuard AI - Frontend Environment Configuration
# Copy this file to .env and configure as needed

# API Base URL Configuration
# Options:
#   - Leave empty/commented for auto-detection (works for both local and deployed)
#   - Set to full URL for explicit backend location
#
# Examples:
#   VITE_API_BASE_URL=http://localhost:8000/api     # Local development
#   VITE_API_BASE_URL=https://your-api.com/api      # Production deployment
#
# Auto-detection logic:
#   1. Uses this env var if set
#   2. If on deployed domain (not localhost), uses same origin
#   3. Falls back to http://localhost:8000/api

# VITE_API_BASE_URL=http://localhost:8000/api
