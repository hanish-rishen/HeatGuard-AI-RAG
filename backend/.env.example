# HeatGuard AI - Backend Environment Configuration
# 
# CONTEXT: This file contains environment variables for the backend API.
# NEIGHBORHOOD: Loaded by app/core/config.py at startup.
#
# IMPORTANT: Copy this file to .env and fill in your actual API keys

# Mistral AI API Key for the Prescriptive RAG Engine
# Get your free API key at: https://console.mistral.ai/
MISTRAL_API_KEY=your_mistral_api_key_here

# ChromaDB Configuration
CHROMA_PERSIST_DIR=./chroma_db

# Model Paths (relative to backend directory)
MODEL_PATH=../Models/heat_health_model_v1.pkl
ENCODER_PATH=../Models/district_encoder.pkl

# API Configuration
HOST=0.0.0.0
PORT=8080
DEBUG=true

# Authentication (JWT)
AUTH_ADMIN_USERNAME=admin
AUTH_ADMIN_PASSWORD=admin123
# Optional: pre-hashed password (HMAC-SHA256 with JWT_SECRET_KEY). If set, AUTH_ADMIN_PASSWORD is ignored.
AUTH_ADMIN_PASSWORD_HASH=
JWT_SECRET_KEY=change-me
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60

