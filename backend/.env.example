# HeatGuard AI - Backend Environment Configuration
# Copy this file to .env and configure for your environment
#
# LOCAL DEVELOPMENT vs DEPLOYMENT:
# - Local: PORT=8000 (or any free port)
# - Leapcell: PORT=8080 (required by platform)
# - CORS_ORIGINS: Leave empty for local dev, set to your frontend domain for production
#
# SECURITY WARNING: Change JWT_SECRET_KEY and AUTH_ADMIN_PASSWORD in production!

# ============================================
# API Configuration
# ============================================
# PORT: 8000 for local, 8080 for Leapcell
HOST=0.0.0.0
PORT=8000
DEBUG=true

# CORS Origins - Comma-separated allowed frontend URLs
# Local: leave empty (allows localhost:*)
# Production: CORS_ORIGINS=https://yourdomain.com
CORS_ORIGINS=

# ============================================
# AI & Model Configuration
# ============================================
MISTRAL_API_KEY=your_mistral_api_key_here
MISTRAL_MODEL=mistral-small-latest
CHROMA_PERSIST_DIR=./chroma_db
CHROMA_COLLECTION_NAME=heat_action_plans

# Model paths relative to backend directory
MODEL_PATH=../Models/heat_health_model_v1.pkl
ENCODER_PATH=../Models/district_encoder.pkl

# ============================================
# Authentication (CHANGE IN PRODUCTION!)
# ============================================
AUTH_ADMIN_USERNAME=admin
AUTH_ADMIN_PASSWORD=admin123
AUTH_ADMIN_PASSWORD_HASH=
JWT_SECRET_KEY=change-me-to-random-string-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60

# ============================================
# Risk Thresholds
# ============================================
RISK_THRESHOLD_GREEN=0.3
RISK_THRESHOLD_AMBER=0.6
